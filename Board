import java.util.ArrayList;
import java.util.List;

public class Board {
    private int rows;
    private int cols;
    private List<Robot> robots = new ArrayList<>();
    private List<BoardElement> elements = new ArrayList<>();

    public Board(int rows, int cols) {
        this.rows = rows;
        this.cols = cols;
    }

    public void addRobot(Robot robot) {
        robots.add(robot);
    }

    public void addElement(BoardElement element) {
        elements.add(element);
    }

    public void move(Robot robot, Direction direction) {
        while (canMove(robot, direction)) {
            robot.step(direction);
        }
    }

    private boolean canMove(Robot robot, Direction direction) {
        int x = robot.getPosition().x;
        int y = robot.getPosition().y;
        int nextX = x;
        int nextY = y;

        switch (direction) {
            case UP:
                nextY--;
                break;
            case DOWN:
                nextY++;
                break;
            case LEFT:
                nextX--;
                break;
            case RIGHT:
                nextX++;
                break;
        }

        if (nextX < 0 || nextX >= cols || nextY < 0 || nextY >= rows) {
            return false;
        }

        for (Robot other : robots) {
            if (other != robot && other.getPosition().x == nextX && other.getPosition().y == nextY) {
                return false;
            }
        }

        return !hasWallBetween(x, y, direction);
    }

    private boolean hasWallBetween(int x, int y, Direction direction) {
        for (BoardElement element : elements) {
            Position p = element.getPosition();

            if (direction == Direction.RIGHT) {
                if (element instanceof EastWall && p.x == x && p.y == y) {
                    return true;
                }
            }

            if (direction == Direction.LEFT) {
                if (element instanceof EastWall && p.x == x - 1 && p.y == y) {
                    return true;
                }
            }

            if (direction == Direction.DOWN) {
                if (element instanceof SouthWall && p.x == x && p.y == y) {
                    return true;
                }
            }

            if (direction == Direction.UP) {
                if (element instanceof SouthWall && p.x == x && p.y == y - 1) {
                    return true;
                }
            }
        }

        return false;
    }

    public boolean gameOver() {
        for (BoardElement element : elements) {
            if (element.gameOver(robots)) {
                return true;
            }
        }
        return false;
    }

    public BoardDisplay createDisplay() {
        BoardDisplay display = new BoardDisplay(rows, cols);

        // Outer right and bottom walls are represented as east/south walls.
        for (int y = 0; y < rows; y++) {
            display.setEastWall(cols - 1, y);
        }

        for (int x = 0; x < cols; x++) {
            display.setSouthWall(x, rows - 1);
        }

        for (BoardElement element : elements) {
            element.renderOn(display);
        }

        for (Robot robot : robots) {
            robot.renderOn(display);
        }

        return display;
    }

    public List<BoardElement> elements() {
        return elements;
    }

    public List<Robot> robots() {
        return robots;
    }
}
